generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  name         String?
  password     String
  role         String   @default("Karyawan")
  roles        String[] @default([]) // Array of roles: ["QC", "Packing", "PotongBahan", "Sewing"]
  status       String   @default("PENDING") // PENDING, ACTIVE
  isActive     Boolean  @default(false) // false = belum diapprove owner
  noHp         String?
  alamat       String?
  tanggalMasuk DateTime?
  payrollType  String   @default("HarianTetap")
  dailyRate    Float    @default(0)
  monthlySalary Float   @default(0)
  pieceRate    Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvedPOs          ProductionOrder[]
  scanLogs             ScanLog[]
  qcRecords            QCRecord[]
  cuttingReports       CuttingReport[]
  sentSewingReports    SewingReport[] @relation("SentBy")
  receivedSewingReports SewingReport[] @relation("ReceivedBy")
  buttonholeRecords    ButtonholeRecord[]
  packingBatches       PackingBatch[]
  customerReturns      CustomerReturn[]
  attendances          Attendance[]
  payrolls             Payroll[]
  sales                Sale[]
  payments             Payment[]
  chatMessages         ChatMessage[]
  shoppingLists        ShoppingList[]
  approvedShoppingLists ShoppingList[] @relation("ShoppingListApprovedBy")
  diterimaShoppingLists ShoppingList[] @relation("ShoppingListDiterimaBy")
  purchaseOrders        PurchaseOrder[]
  materialUsages        MaterialUsage[]
}

model Bahan {
  id          String   @id @default(cuid())
  kode        String   @unique
  nama        String
  satuan      String   // Kilo (Kg), Meter (M), Pcs
  warna       String   // Primary/default color (backward compat)
  warnaList   String   @default("[]") // JSON array: ["HITAM","PUTIH","NAVY"]
  stok        Float    @default(0)
  hargaBeli   Float    @default(0)
  stokMinimum Float    @default(0)
  kategori    String   @default("Kain") // Kain / Aksesoris
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  poBahanEstimasis  POBahanEstimasi[]
  cuttingDetails    CuttingReportDetail[]
  shoppingListItems ShoppingListItem[]
  purchaseOrderItems PurchaseOrderItem[]
  materialUsages     MaterialUsage[]
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  code        String   @unique
  supplier    String
  status      String   @default("Draft") // Draft, Ordered, Received, Done
  notes       String?
  fakturNo    String?  // No. Faktur / Nota Supplier (filled at receiving)
  hargaBeli   Float?   // Harga beli per satuan (filled at receiving)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PurchaseOrderItem[]

  @@index([code])
  @@index([status])
  @@index([createdById])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  bahanId         String
  bahan           Bahan         @relation(fields: [bahanId], references: [id])
  warna           String        // color name
  rollOrdered     Int           @default(0) // number of rolls ordered
  weightsJson     String        @default("[]") // JSON: [{"roll":1,"weight":25.5},...]
  totalWeight     Float         @default(0) // sum of all roll weights
  price           Float         @default(0) // totalWeight * hargaBeli
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
  @@index([bahanId])
}

model MaterialUsage {
  id          String   @id @default(cuid())
  modelName   String   // Nama Model Baju / Artikel
  bahanId     String
  bahan       Bahan    @relation(fields: [bahanId], references: [id])
  warna       String
  rollCount   Int      @default(0)
  totalWeight Float    @default(0)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([bahanId])
  @@index([createdAt])
}

model ShoppingList {
  id            String   @id @default(cuid())
  code          String   @unique
  status        String   @default("Draft") // Draft, PendingApproval, Approved, Diterima, Done, Cancelled
  notes         String?
  buktiUrl      String?  // Foto surat jalan dari supplier/toko
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  approvedById  String?
  approvedBy    User?    @relation("ShoppingListApprovedBy", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  diterimaById  String?
  diterimaBy    User?    @relation("ShoppingListDiterimaBy", fields: [diterimaById], references: [id])
  diterimaAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items ShoppingListItem[]

  @@index([code])
  @@index([status])
  @@index([createdById])
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  bahanId        String
  bahan          Bahan        @relation(fields: [bahanId], references: [id])
  warna          String
  rolls          String       @default("") // Comma-separated roll weights: "25.55, 25.80, 25.80, 25.90"
  totalKg        Float        @default(0)
  totalMeter     Float        @default(0)
  hargaPerKg     Float        @default(0)
  hargaPerMeter  Float        @default(0)
  createdAt      DateTime     @default(now())

  @@index([shoppingListId])
  @@index([bahanId])
}

model Produk {
  id        String   @id @default(cuid())
  kode      String   @unique
  nama      String
  deskripsi String?
  fotoUrl   String?
  namaFoto  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Bagian 1 - Basic
  kategoriId    String?
  kategori      Kategori? @relation(fields: [kategoriId], references: [id])
  videoUrl      String?
  promoLongImg  String?
  whiteBgImg    String?

  // Bagian 2 - Qualification
  halalCert String?
  licenseCode String?

  // Bagian 3 - Specification
  brand          String?
  material       String?
  neckline       String?
  pattern        String?
  jubahLength    String?
  sleevesType    String?
  style          String?

  // Bagian 5 - Size Chart
  sizeChartImg String?

  // Bagian 6 - Description HTML
  descHtml String?

  // Bagian 7 - Shipping
  weight        Float  @default(0)
  length        Float  @default(0)
  width         Float  @default(0)
  height        Float  @default(0)
  dangerousGoods String @default("None")

  variasi       ProdukVariasi[]
  garmentPieces GarmentPiece[]
  images        ProdukImage[]
  labels        ProdukLabel[]
  orderItems    CustomerOrderItem[]
}

model Kategori {
  id       String   @id @default(cuid())
  nama     String   @unique
  parentId String?
  produk   Produk[]
}

model ProdukImage {
  id        String @id @default(cuid())
  produkId  String
  produk    Produk @relation(fields: [produkId], references: [id], onDelete: Cascade)
  url       String
  warna     String?
  isPrimary Boolean @default(false)
  order     Int     @default(0)
}

model ProdukVariasi {
  id             String   @id @default(cuid())
  produkId       String
  produk         Produk   @relation(fields: [produkId], references: [id], onDelete: Cascade)
  size           String
  warna          String
  sku            String   @unique
  fotoPath       String?
  fotoUrl        String?
  namaFoto       String?
  hargaProduksi  Float    @default(0)
  barcode        String?
  price          Float    @default(0)
  specialPrice   Float?
  hargaDiskon    Float?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)

  @@unique([produkId, size, warna])
  @@index([sku])

  poItems     POItem[]
  promoItems  PromoItem[]
  orderItems  CustomerOrderItem[]
}

model Promo {
  id          String   @id @default(cuid())
  nama        String
  jenis       String   // "persen" or "nominal"
  nilai       Float    // 20 (for 20%) or 25000 (for nominal)
  tglMulai    DateTime
  tglSelesai  DateTime
  status      String   @default("Draft") // Draft, Active, Completed, Cancelled
  marketplace String   @default("All") // All, Shopee, Lazada, Akulaku
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PromoItem[]
}

model PromoItem {
  id              String       @id @default(cuid())
  promoId         String
  promo           Promo        @relation(fields: [promoId], references: [id], onDelete: Cascade)
  produkVariasiId String
  variasi         ProdukVariasi @relation(fields: [produkVariasiId], references: [id])
  createdAt       DateTime     @default(now())

  @@unique([promoId, produkVariasiId])
}

model PromoLabel {
  id        String   @id @default(cuid())
  nama      String   @unique
  icon      String?
  color     String?
  otomatis  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  assignments ProdukLabel[]
}

model ProdukLabel {
  id        String     @id @default(cuid())
  produkId  String
  produk    Produk     @relation(fields: [produkId], references: [id], onDelete: Cascade)
  labelId   String
  label     PromoLabel @relation(fields: [labelId], references: [id])
  warna     String?    // null = all colors
  size      String?    // null = all sizes
  sku       String?    // null = all SKUs
  createdAt DateTime   @default(now())

  @@unique([produkId, labelId, warna, size, sku])
  @@index([produkId])
  @@index([labelId])
}

model SewingPartner {
  id            String        @id @default(cuid())
  nama          String        @unique
  sewingReports SewingReport[]
}

model ProductionOrder {
  id           String   @id @default(cuid())
  code         String   @unique
  status       String   @default("Draft")
  notes        String?
  approvedById String?
  approvedBy   User?    @relation(fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items          POItem[]
  bahanEstimasi  POBahanEstimasi[]
  garmentPieces  GarmentPiece[]
  cuttingReports CuttingReport[]
  sewingReports  SewingReport[]
  packingBatches PackingBatch[]
}

model POItem {
  id              String          @id @default(cuid())
  poId            String
  po              ProductionOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  produkVariasiId String
  variasi         ProdukVariasi   @relation(fields: [produkVariasiId], references: [id])
  targetQty       Int
  estimasiBiaya   Float?
  estimasiHargaMasuk Float?

  @@unique([poId, produkVariasiId])
  @@index([poId])
}

model POBahanEstimasi {
  id              String          @id @default(cuid())
  poId            String
  po              ProductionOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  bahanId         String
  bahan           Bahan           @relation(fields: [bahanId], references: [id])
  estimatedAmount Float

  @@unique([poId, bahanId])
  @@index([poId])
}

model GarmentPiece {
  id               String   @id @default(cuid())
  barcode          String   @unique
  poId             String
  po               ProductionOrder @relation(fields: [poId], references: [id])
  produkId         String
  produk           Produk   @relation(fields: [produkId], references: [id])
  size             String
  color            String
  sewerName        String?
  cuttingDate      DateTime?
  currentStage     String   @default("Cut")
  cuttingReportId  String?
  cuttingReport    CuttingReport? @relation(fields: [cuttingReportId], references: [id])

  scanLogs    ScanLog[]
  qcRecords   QCRecord[]
  sewingDetails    SewingReportDetail[]
  buttonholeRecords ButtonholeRecord[]
  packingItems      PackingBatchItem[]
  customerReturns   CustomerReturn[]
  saleItems         SaleItem[]

  @@index([barcode])
  @@index([poId])
  @@index([sewerName])
}

model ScanLog {
  id          String   @id @default(cuid())
  barcodeUnitId String
  barcodeUnit GarmentPiece @relation(fields: [barcodeUnitId], references: [id])
  stage       String
  scannedById String
  scannedBy   User     @relation(fields: [scannedById], references: [id])
  scannedAt   DateTime @default(now())
  notes       String?

  @@index([barcodeUnitId])
  @@index([scannedAt])
}

model QCRecord {
  id              String   @id @default(cuid())
  barcodeUnitId   String
  barcodeUnit     GarmentPiece @relation(fields: [barcodeUnitId], references: [id])
  qcStage         String
  result          String
  defectPhotoPath String?
  qcById          String
  qcBy            User     @relation(fields: [qcById], references: [id])
  qcAt            DateTime @default(now())
  notes           String?

  @@index([barcodeUnitId])
  @@index([qcById])
}

model CuttingReport {
  id                String   @id @default(cuid())
  poId              String
  po                ProductionOrder @relation(fields: [poId], references: [id])
  reportDate        DateTime @default(now())
  panelLength       Float?
  panelCount        Int?
  totalMaterialUsed Float?
  totalResultQty    Int?
  photoPath         String?
  cutById           String
  cutBy             User     @relation(fields: [cutById], references: [id])
  createdAt         DateTime @default(now())

  details          CuttingReportDetail[]
  garmentPieces    GarmentPiece[]

  @@index([poId])
}

model CuttingReportDetail {
  id                String        @id @default(cuid())
  cuttingReportId   String
  cuttingReport     CuttingReport @relation(fields: [cuttingReportId], references: [id], onDelete: Cascade)
  bahanId           String
  bahan             Bahan         @relation(fields: [bahanId], references: [id])
  size              String
  warna             String
  unitUsedMode      String
  amountUsed        Float
  cuttingCount      Int
  perPieceMultiplier Int
  resultQty         Int

  @@index([cuttingReportId])
}

model SewingReport {
  id            String   @id @default(cuid())
  poId          String?
  po            ProductionOrder? @relation(fields: [poId], references: [id])
  partnerId     String
  partner       SewingPartner @relation(fields: [partnerId], references: [id])
  sentById      String
  sentBy        User     @relation("SentBy", fields: [sentById], references: [id])
  sentAt        DateTime @default(now())
  receivedById  String?
  receivedBy    User?    @relation("ReceivedBy", fields: [receivedById], references: [id])
  receivedAt    DateTime?
  status        String   @default("Sent")
  notes         String?
  createdAt     DateTime @default(now())

  details SewingReportDetail[]

  @@index([partnerId])
  @@index([poId])
}

model SewingReportDetail {
  id              String       @id @default(cuid())
  sewingReportId  String
  sewingReport    SewingReport @relation(fields: [sewingReportId], references: [id], onDelete: Cascade)
  barcodeUnitId   String
  barcodeUnit     GarmentPiece @relation(fields: [barcodeUnitId], references: [id])
  status          String       @default("Sent")
  receivedAt      DateTime?

  @@unique([sewingReportId, barcodeUnitId])
  @@index([barcodeUnitId])
}

model ButtonholeRecord {
  id            String   @id @default(cuid())
  barcodeUnitId String
  barcodeUnit   GarmentPiece @relation(fields: [barcodeUnitId], references: [id])
  doneById      String
  doneBy        User     @relation(fields: [doneById], references: [id])
  doneAt        DateTime @default(now())
  notes         String?

  @@index([barcodeUnitId])
}

model PackingBatch {
  id            String   @id @default(cuid())
  batchNumber   String   @unique
  poId          String?
  po            ProductionOrder? @relation(fields: [poId], references: [id])
  packedById    String
  packedBy      User     @relation(fields: [packedById], references: [id])
  packedAt      DateTime @default(now())
  totalPieces   Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  items PackingBatchItem[]

  @@index([batchNumber])
  @@index([poId])
}

model PackingBatchItem {
  id             String       @id @default(cuid())
  packingBatchId String
  packingBatch   PackingBatch @relation(fields: [packingBatchId], references: [id], onDelete: Cascade)
  barcodeUnitId  String
  barcodeUnit    GarmentPiece @relation(fields: [barcodeUnitId], references: [id])

  @@unique([packingBatchId, barcodeUnitId])
  @@index([barcodeUnitId])
}

model CustomerReturn {
  id            String   @id @default(cuid())
  barcodeUnitId String
  barcodeUnit   GarmentPiece @relation(fields: [barcodeUnitId], references: [id])
  returnDate    DateTime @default(now())
  reason        String
  condition     String
  returnedById  String
  returnedBy    User     @relation(fields: [returnedById], references: [id])
  notes         String?
  createdAt     DateTime @default(now())

  @@index([barcodeUnitId])
}

model EcommerceSale {
  id            String   @id @default(cuid())
  platform      String
  orderId       String
  orderDate     DateTime
  customerName  String?
  totalAmount   Float
  shippingCost  Float    @default(0)
  platformFee   Float    @default(0)
  netAmount     Float    @default(0)
  status        String   @default("Processing")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payments Payment[]

  @@unique([platform, orderId])
  @@index([platform])
  @@index([orderDate])
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tanggal   DateTime
  clockIn   DateTime?
  clockOut  DateTime?
  isPresent Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, tanggal])
  @@index([userId])
  @@index([tanggal])
}

model Payroll {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  periode     String
  totalDays   Int      @default(0)
  totalPieces Int      @default(0)
  basePay     Float    @default(0)
  bonus       Float    @default(0)
  deductions  Float    @default(0)
  netPay      Float    @default(0)
  status      String   @default("Draft")
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([userId, periode])
  @@index([userId])
  @@index([periode])
}

model Sale {
  id           String   @id @default(cuid())
  saleDate     DateTime @default(now())
  customerName String?
  totalAmount  Float    @default(0)
  soldById     String
  soldBy       User     @relation(fields: [soldById], references: [id])
  notes        String?
  createdAt    DateTime @default(now())

  items    SaleItem[]
  payments Payment[]

  @@index([saleDate])
}

model SaleItem {
  id            String     @id @default(cuid())
  saleId        String
  sale          Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  barcodeUnitId String
  barcodeUnit   GarmentPiece @relation(fields: [barcodeUnitId], references: [id])
  price         Float      @default(0)

  @@unique([saleId, barcodeUnitId])
  @@index([barcodeUnitId])
}

model Payment {
  id              String   @id @default(cuid())
  ecommerceSaleId String?
  ecommerceSale   EcommerceSale? @relation(fields: [ecommerceSaleId], references: [id])
  saleId          String?
  sale            Sale?    @relation(fields: [saleId], references: [id])
  amount          Float
  paymentMethod   String
  paymentDate     DateTime
  status          String   @default("Pending")
  referenceNumber String?
  notes           String?
  recordedById    String
  recordedBy      User     @relation(fields: [recordedById], references: [id])
  createdAt       DateTime @default(now())

  @@index([ecommerceSaleId])
  @@index([saleId])
  @@index([paymentDate])
  @@index([status])
}

model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  address   String
  kota      String
  provinsi  String
  kodePos   String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses CustomerAddress[]
  orders    CustomerOrder[]

  @@index([email])
  @@index([phone])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Utama")
  name       String
  phone      String
  address    String
  kota       String
  provinsi   String
  kodePos    String?
  catatan    String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CustomerOrder {
  id               String   @id @default(cuid())
  invoice          String   @unique
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  customerName     String
  customerPhone    String
  customerAddress  String
  customerKota     String
  customerProvinsi String
  catatan          String?
  status           String   @default("Menunggu Pembayaran")
  paymentMethod    String
  paymentStatus    String   @default("Pending")
  shippingCost     Float    @default(0)
  totalAmount      Float    @default(0)
  grandTotal       Float    @default(0)
  kurir            String?
  resi             String?
  paymentProof     String?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items CustomerOrderItem[]

  @@index([invoice])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model CustomerOrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  produkId        String
  produk          Produk        @relation(fields: [produkId], references: [id])
  produkVariasiId String
  variasi         ProdukVariasi @relation(fields: [produkVariasiId], references: [id])
  namaProduk      String
  size            String
  warna           String
  quantity        Int           @default(1)
  price           Float         @default(0)
  subtotal        Float         @default(0)

  @@index([orderId])
  @@index([produkVariasiId])
}
